# ============================================================
# Environment Variables — copy this to .env and fill in values
# NEVER commit the actual .env file to Git
# ============================================================

# --- Application ---
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
PORT=8000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fraud_credit_db
POSTGRES_USER=mluser
POSTGRES_PASSWORD=mlpassword
DATABASE_URL=postgresql://mluser:mlpassword@localhost:5432/fraud_credit_db

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=fraud-credit-system

# --- Model Registry Names ---
FRAUD_MODEL_NAME=FraudDetector-v1
CREDIT_MODEL_NAME=CreditRiskScorer-v1
MODEL_STAGE=Production

# --- Data Paths ---
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
MODELS_DIR=outputs/models
OUTPUTS_DIR=outputs

# --- Monitoring ---
DRIFT_THRESHOLD=0.15         # Evidently PSI threshold for alerts
PROMETHEUS_PORT=9090
